HF_TOKEN=여기에_HuggingFace_토큰_입력

ASR_MODEL=ghost613/faster-whisper-large-v3-turbo-korean
NMT_ASR_MODEL=Helsinki-NLP/opus-mt-ko-en
TTS_MODEL=piper
OCR_MODEL=rapidocr

ASR_DEVICE=cuda
NMT_ASR_DEVICE=cpu
TTS_DEVICE=cpu
OCR_DEVICE=cpu

# ============================================
# 서버 시작 시 모델 로딩 스킵 (슬라이드 번역 전용 모드)
# ============================================
SKIP_STARTUP_MODELS=true

# ============================================
# VLM (슬라이드 번역) 설정
# ============================================
VLM_BASE_MODEL=Qwen/Qwen3-VL-8B-Instruct
VLM_LORA_PATH=models/qwen3/qwen3-vl-8b-lora-r64-e3-final
VLM_DEVICE=cuda
VLM_MAX_GPU_MEMORY=6GB
VLM_USE_4BIT=true

# Python 경로 (본인 환경에 맞게 수정)
# Windows 예시: C:/Users/사용자명/AppData/Local/Programs/Python/Python311/python.exe
# Linux/Mac 예시: /usr/bin/python3
PYTHON_PATH=여기에_Python_경로_입력
