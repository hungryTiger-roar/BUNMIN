HF_TOKEN=

# OpenAI API 키 (선택사항 — 슬라이드 번역 시 용어집 자동 생성에 사용)
# 없으면 용어집 빌드를 건너뛰고 번역을 진행합니다 (번역 품질에 영향 있음)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=

# 모델 값은 (1) 프로젝트 루트 기준 상대 경로, (2) 절대 경로, (3) HF repo_id 셋 다 허용
# 로컬 경로면 from_pretrained 직접 로드, repo_id면 HF 캐시 다운로드
# 기본값은 setup이 받은 로컬 경로 — Windows 심볼릭/Electron 배포 환경 호환
ASR_MODEL=models/whisper-large-v3-turbo-ct2-int8
NMT_ASR_MODEL=Helsinki-NLP/opus-mt-ko-en
OCR_MODEL=rapidocr

ASR_DEVICE=cuda
NMT_ASR_DEVICE=cpu
OCR_DEVICE=cpu

# ============================================
# 서버 시작 시 모델 로딩 여부
# false: 실시간 번역 전체 기능 (ASR + NMT + OCR 로드) ← 신규 사용자 기본값
# true:  슬라이드 번역 전용 모드 (VLM만 사용, 나머지 스킵)
# ============================================
SKIP_STARTUP_MODELS=true

# ============================================
# VLM (슬라이드 번역) 설정
# ============================================
# 비워두면 코드가 자동으로 감지: 로컬 models/qwen3-vl-8b-instruct/ 우선, 없으면 HF repo_id
# 명시 오버라이드가 필요할 때만 주석 해제
# VLM_BASE_MODEL=Qwen/Qwen3-VL-8B-Instruct
VLM_LORA_PATH=models/qwen3/qwen3-vl-8b-lora-r64-e3-final
VLM_DEVICE=cuda
VLM_MAX_GPU_MEMORY=4GB
VLM_USE_4BIT=true
