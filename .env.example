# ============================================
# Aunion AI — 환경설정 예시
#   `cp .env.example .env` 후 토큰·경로만 채우면 됨.
#   값 형식: 모델은 (1) 프로젝트 루트 기준 상대경로 (2) 절대경로 (3) HF repo_id 모두 허용.
# ============================================

# --- API 키 -------------------------------------------------
# HuggingFace 토큰 — gated 모델 다운로드 시 필요. 공개 모델만 쓰면 비워둬도 됨.
HF_TOKEN=

# --- 실시간 모델 (ASR / NMT / OCR) --------------------------
# 로컬 경로면 from_pretrained 직접 로드, repo_id면 HF 캐시로 다운로드.
# 기본값은 setup이 받은 로컬 경로 — Windows 심볼릭/Electron 배포 환경 호환.
ASR_MODEL=models/whisper-large-v3-turbo-ct2-int8
NMT_ASR_MODEL=facebook/nllb-200-distilled-600M
OCR_MODEL=surya

# 디바이스: cuda(GPU) 또는 cpu. GPU 없으면 cpu (느려짐 — 특히 ASR).
ASR_DEVICE=cuda
NMT_ASR_DEVICE=cuda
OCR_DEVICE=cuda

# ============================================
# VLM (슬라이드 번역) 설정 — Qwen3-VL-4B
# ============================================
# 양자화(4bit/8bit) + max_memory 는 VRAM 자동 감지 (코드가 환경에 맞게 결정):
#   < 7.5GB → 4bit          (6GB 카드 — weight 2.5GB, OCR+Electron 함께도 안전)
#   7.5 ~ 12GB → 8bit        (8GB 카드 — max_memory = total - 2GiB)
#   ≥ 12GB → 8bit            (12GB+ — max_memory = total - 3GiB)
VLM_BASE_MODEL=Qwen/Qwen3-VL-4B-Instruct
VLM_DEVICE=cuda

# ============================================
# PDF 텍스트 레이어 번역 설정
# ============================================
# 한글 폰트 경로 (Windows: malgun.ttf, Linux: NotoSansKR)
KOREAN_FONT_PATH=C:/Windows/Fonts/malgun.ttf

# 이미지 배경 감지 variance threshold (높을수록 이미지로 판단)
IMAGE_BG_VARIANCE_THRESHOLD=150

# Role별 최소 폰트 크기
MIN_FONT_SIZE_TITLE=14.0
MIN_FONT_SIZE_HEADING=12.0
MIN_FONT_SIZE_BODY=10.0
MIN_FONT_SIZE_CAPTION=6.0
MIN_FONT_SIZE_DEFAULT=8.0

# ============================================
# OCR / VLM 배치 처리 설정
# ============================================
# OCR 청크 크기 (Surya 한 번 로드로 처리할 페이지 수)
OCR_CHUNK_SIZE=5

# VLM 번역 청크 크기 (VLM 한 번 로드로 처리할 페이지 수)
VLM_CHUNK_SIZE=2

# 중간 결과 캐시 디렉토리 (재시작 시 이전 단계 결과 재사용).
# 미설정 시 frozen 은 %LOCALAPPDATA%\Aunion AI\uploads\cache\, dev 는 <repo>/uploads/cache/ 사용.
# 명시할 때는 절대경로 권장 — 상대경로면 백엔드 spawn CWD 기준이라 불안정.
# CACHE_DIR=

# ============================================
# 프론트엔드 sync 설정 (Vite 빌드 시점 inject)
# ============================================
# 수강자측 wall-clock delay-buffer 기준 lag (ms) — baseDelay (초기/무발화 구간 유지값).
# 강사 wall-clock 기준 원본 음성 / TTS / 그림 / 자막을 모두 이 시간만큼 지연 정렬하고,
# 4번째 발화부터는 적응형 currentDelay = P90(필요딜레이) + max(300ms, stddev×1.5) 가 인계,
# [2초, 20초] 범위에서 자동 조정. 모든 트랙이 같은 currentDelay 공유 → 셋의 상대 싱크는 100% 정합.
#
# 권장값(GPU 환경 처리시간 P90 ≈ 3s + 안전마진):
#   3000  : 스트리밍 ASR 파이프라인 수렴값 (~2850ms) 기준 ← 기본
#   5000  : 배치 모드 (force-split) 파이프라인 기준
#   10000 : 옛값. 너무 보수적, 메모리 정책 위배
# 변경 후 frontend 재빌드 필요 (npm run build --prefix frontend).
# 실측 [DelayBuf] delay=XXms 로그 분포 보고 fine-tune 가능.
VITE_SYNC_DELAY_MS=3000
