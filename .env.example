HF_TOKEN=

# OpenAI API 키 (선택사항 — 슬라이드 번역 시 용어집 자동 생성에 사용)
# 없으면 용어집 빌드를 건너뛰고 번역을 진행합니다 (번역 품질에 영향 있음)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=

# 모델 값은 (1) 프로젝트 루트 기준 상대 경로, (2) 절대 경로, (3) HF repo_id 셋 다 허용
# 로컬 경로면 from_pretrained 직접 로드, repo_id면 HF 캐시 다운로드
# 기본값은 setup이 받은 로컬 경로 — Windows 심볼릭/Electron 배포 환경 호환
ASR_MODEL=models/whisper-large-v3-turbo-ct2-int8
NMT_ASR_MODEL=facebook/nllb-200-distilled-600M
OCR_MODEL=surya

ASR_DEVICE=cuda
NMT_ASR_DEVICE=cuda
OCR_DEVICE=cpu

# ============================================
# 서버 시작 시 모델 로딩 여부
# false: 실시간 번역 전체 기능 (ASR + NMT + OCR 로드) ← 신규 사용자 기본값
# true:  슬라이드 번역 전용 모드 (VLM만 사용, 나머지 스킵)
# ============================================
SKIP_STARTUP_MODELS=true

# ============================================
# Streaming ASR (실험 기능)
# true:  faster-whisper 를 streaming 모드로 운용. 호흡 없이 길게 말하는 강사
#        케이스에서 첫 자막 latency ~50% 감소. 짧은 1문장에서는 chunk 모드와 거의 동일.
#        GPU 사용량 +20-30% (overlap transcribe).
# false: 기존 chunk-based + KSS 동작 (안정 모드, 디폴트)
# 롤백: ASR_STREAMING=false 로 되돌리고 backend 재시작.
#       코드 단위 롤백은 `git reset --hard pre-streaming-asr-rollback`.
# 동기화: backend 가 register ack 로 frontend 에 통보 → 자동 매칭.
# ============================================
ASR_STREAMING=false

# Streaming 튜닝 상수 (ASR_STREAMING=true 일 때만 의미 있음).
# 모르면 그대로 유지 — 운영 중 latency / GPU 부하 균형 잡을 때만 건드림.
# 변경 시 backend 프로세스 재시작 필요 (모듈 import 시 한 번만 읽음).
#   GRACE_SEC:        종결어미 직후 다음 word 기다리는 시간. ↓ → finalize 빠름 / 합칠 단어 미리 잘릴 위험 ↑
#   INTERVAL_SEC:     transcribe throttle. ↑ → GPU 부하 ↓ / 자막 lag ↑
#   MAX_BUFFER_SEC:   종결어미 못 잡았을 때 강제 finalize 시점. ↓ → 정상 발화도 잘릴 수 있음
#   MIN_BUFFER_SEC:   transcribe 시도 최소 buffer. ↓ → 너무 잦은 transcribe 호출
ASR_STREAMING_GRACE_SEC=0.3
ASR_STREAMING_INTERVAL_SEC=0.25
# 8s 권장 — 22~66s buffer 누적 시 학생측 visual sync 어긋남. 너무 작으면 정상 발화 잘림.
ASR_STREAMING_MAX_BUFFER_SEC=8.0
ASR_STREAMING_MIN_BUFFER_SEC=0.4

# ============================================
# 진단 로그 (Sync Debug)
# 강사/학생 send/recv 흐름과 sentence 큐 처리 timing 콘솔/터미널에 출력.
# 평소 false (성능). 문제 진단 시만 true.
# ============================================
# 백엔드 (서버 콘솔에 [Diag/Server] recv/broadcast 로그 출력)
SYNC_DEBUG=false

# 프론트엔드 (브라우저 F12 콘솔에 [L→S] / [S←L] / [Diag] 출력)
# 페이지 로드 시 자동으로 window.__SYNC_DEBUG = true 세팅됨.
# 콘솔에서 수동 토글하려면 false 로 두고 window.__SYNC_DEBUG = true.
VITE_SYNC_DEBUG=false

# ============================================
# Sync Mode (학생측 visual ↔ audio 동기화 전략)
# ============================================
# unit-stretch (권장): TTS 가 master. 그림/커서/페이지를 TTS 길이에 stretch.
#                      발화 사이 침묵은 강사 원래 박자 (silent unit).
#                      그림 ↔ 음성 100% 동시. 영어 TTS 가 길어 누적 lag 발생
#                      (예: 60분 강의 → 학생 ~78분).
# delay-buffer       : wall-clock + 고정 lag. stretch 없음. drift 가능.
VITE_SYNC_MODE=unit-stretch

# delay-buffer 모드 전용 — unit-stretch 에서는 무시됨.
VITE_SYNC_DELAY_MS=15000

# ============================================
# VLM (슬라이드 번역) 설정
# ============================================
# 비워두면 코드가 자동 감지: 로컬 models/qwen2.5-vl-7b-instruct/ 우선, 없으면 HF repo_id
# 명시 오버라이드가 필요할 때만 다음 라인 활성화
VLM_BASE_MODEL=models/qwen2.5-vl-7b-instruct
VLM_DEVICE=cuda
VLM_MAX_GPU_MEMORY=4GB
VLM_USE_4BIT=true
