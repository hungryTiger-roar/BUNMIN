# ============================================
# Aunion AI — 환경설정 예시
#   `cp .env.example .env` 후 토큰·경로만 채우면 됨.
#   값 형식: 모델은 (1) 프로젝트 루트 기준 상대경로 (2) 절대경로 (3) HF repo_id 모두 허용.
# ============================================

# --- API 키 -------------------------------------------------
# HuggingFace 토큰 — gated 모델 다운로드 시 필요. 공개 모델만 쓰면 비워둬도 됨.
HF_TOKEN=

# OpenAI API 키 (선택 — 슬라이드 번역 시 용어집 자동 생성에 사용)
# 없으면 용어집 빌드를 건너뛰고 번역을 진행합니다 (번역 품질에 영향 있음)
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=

# --- 실시간 모델 (ASR / NMT / OCR) --------------------------
# 로컬 경로면 from_pretrained 직접 로드, repo_id면 HF 캐시로 다운로드.
# 기본값은 setup이 받은 로컬 경로 — Windows 심볼릭/Electron 배포 환경 호환.
ASR_MODEL=models/whisper-large-v3-turbo-ct2-int8
NMT_ASR_MODEL=facebook/nllb-200-distilled-600M
OCR_MODEL=surya

# 디바이스: cuda(GPU) 또는 cpu. GPU 없으면 cpu (느려짐 — 특히 ASR).
ASR_DEVICE=cuda
NMT_ASR_DEVICE=cuda
OCR_DEVICE=cuda

# ============================================
# 서버 시작 시 모델 로딩 여부
#   false: 실시간 번역 전체 기능 (ASR + NMT + OCR 로드) ← 신규 사용자 기본값
#   true:  슬라이드 번역 전용 모드 (VLM만 사용, 나머지 스킵)
# ============================================
SKIP_STARTUP_MODELS=false

# ============================================
# VLM (슬라이드 번역) 설정
# ============================================
# 비워두면 코드가 자동 감지: 로컬 models/qwen2.5-vl-7b-instruct/ 우선, 없으면 HF repo_id.
# 명시 오버라이드가 필요할 때만 다음 라인 활성화.
VLM_BASE_MODEL=models/qwen2.5-vl-7b-instruct
VLM_DEVICE=cuda
VLM_MAX_GPU_MEMORY=5.5GB        # GPU VRAM 상한 (4bit 로드 시 7B ≈ 5~6GB). 카드에 맞춰 조정
VLM_USE_4BIT=true

# ============================================
# 슬라이드 번역 파이프라인 선택
#   true:  새 파이프라인 (slide_translation 모듈)
#   false: 기존 파이프라인 (translate_slide_v3.py)
# ============================================
USE_NEW_SLIDE_PIPELINE=true

# ============================================
# PDF 텍스트 레이어 번역 설정
# ============================================
# 한글 폰트 경로 (Windows: malgun.ttf, Linux: NotoSansKR)
KOREAN_FONT_PATH=C:/Windows/Fonts/malgun.ttf

# 이미지 배경 감지 variance threshold (높을수록 이미지로 판단)
IMAGE_BG_VARIANCE_THRESHOLD=150

# Role별 최소 폰트 크기
MIN_FONT_SIZE_TITLE=14.0
MIN_FONT_SIZE_HEADING=12.0
MIN_FONT_SIZE_BODY=10.0
MIN_FONT_SIZE_CAPTION=6.0
MIN_FONT_SIZE_DEFAULT=8.0

# ============================================
# OCR / VLM 배치 처리 설정
# ============================================
# OCR 청크 크기 (Surya 한 번 로드로 처리할 페이지 수)
OCR_CHUNK_SIZE=5

# VLM 번역 청크 크기 (VLM 한 번 로드로 처리할 페이지 수)
VLM_CHUNK_SIZE=2

# 중간 결과 캐시 디렉토리 (재시작 시 이전 단계 결과 재사용)
CACHE_DIR=uploads/cache

# ============================================
# 프론트엔드 sync 설정 (Vite 빌드 시점 inject)
# ============================================
# 수강자측 wall-clock delay-buffer 기준 lag (ms).
# 강사 wall-clock 기준 원본 음성 / TTS / 그림 / 자막을 모두 이 시간만큼 지연 정렬하고,
# 실제 lag 은 처리시간(ASR+NMT+TTS) 추적해 [2초, 20초] 범위에서 적응형으로 조정됨.
# 줄이면 라이브감 ↑ / jitter 흡수 ↓, 늘리면 안정성 ↑ / lag ↑. 변경 후 프론트 재빌드 필요 (npm run build).
# 2000 = DELAY_MIN_MS 와 동일 (그림만 그리는 무발화 구간 baseDelay). 발화 시작하면 적응형이
# 자동으로 5~7s 로 상향. "강의 딜레이 최소화 최우선" 정책에 맞춰 baseDelay 를 하한으로 둠.
# 실측 [LATENCY] 로그의 '전체' 분포 보고 추가 조정 가능 (안전 마진 1~2초 권장).
VITE_SYNC_DELAY_MS=2000
