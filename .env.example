HF_TOKEN=

ASR_MODEL=models/whisper-large-v3-turbo-ct2-int8
NMT_ASR_MODEL=Helsinki-NLP/opus-mt-ko-en
OCR_MODEL=rapidocr

ASR_DEVICE=cuda
NMT_ASR_DEVICE=cpu
OCR_DEVICE=cpu

# ============================================
# 서버 시작 시 모델 로딩 스킵 (슬라이드 번역 전용 모드)
# ============================================
SKIP_STARTUP_MODELS=true

# ============================================
# VLM (슬라이드 번역) 설정
# ============================================
# 비워두면 코드가 자동으로 감지: 로컬 models/qwen3-vl-8b-instruct/ 우선, 없으면 HF repo_id
# 명시 오버라이드가 필요할 때만 주석 해제
# VLM_BASE_MODEL=Qwen/Qwen3-VL-8B-Instruct
VLM_LORA_PATH=models/qwen3/qwen3-vl-8b-lora-r64-e3-final
VLM_DEVICE=cuda
VLM_MAX_GPU_MEMORY=6GB
VLM_USE_4BIT=true

# ============================================
# OpenAI API (용어집 빌드 전용)
# ============================================
OPENAI_API_KEY=