*.pyc
.venv/
.cache/
*.egg-info/
.env
.env.*
!.env.example
server.log
error_log.txt
*.log

# 빌드 산출물
setup/
node_modules/
*.tsbuildinfo
build_tmp/

# AI 모델 가중치 (어느 위치에 있어도 차단)
*.bin
*.safetensors
*.onnx
*.pt
*.pth

# VAD 런타임 모델 — 작은 크기(~2MB), 프론트엔드 필수 파일이므로 예외
!frontend/public/silero_vad_*.onnx

# 다운로드 모델 디렉토리 — 전체 ignore
# (모델은 npm run setup 에서 받음, git 추적 X)
models/

# 업로드 파일 (슬라이드, 이미지) — 항상 프로젝트 루트에 생성됨
uploads/

# 보안
*.pem
*.key
*.cert
*.p12

# 테스트/커버리지
.pytest_cache/
.coverage
htmlcov/

# 평가
evaluation/datasets/
evaluation/datasets.zip
evaluation/results/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# 평가용 다운로드 PDF
evaluation/pdfs/
evaluation/datasets/ocr_pdfs/

# 용어집 캐시 (glossary_builder.py가 런타임에 자동 생성)
glossary/

# Claude
.claude/

# 자동 생성 API 문서
docs/api/

# 테스트 파일 및 출력물 (프로젝트 루트)
test_*.py
test_*.png
test_*.pdf
test_*.json
test_*.txt
compare_*.py
create_*.py
inference_vlm.py
run_test.bat
check_p*.png
*_regions.json
*_translated*.json
*_translated*.png

# 레거시 스크립트 (v3 사용)
translate_slide.py
translate_slide_v2.py

# 프론트엔드 빌드 캐시
frontend/.vite/

# 로컬 모델 캐시 (백엔드 서비스 자체 캐시)
backend/app/services/models/

# 로컬 데이터셋
datasets/
backend/app/services/slide_translation/glossaries/*.json

# 임시 파일 (커밋 메시지 작성용 등)
*.tmp

# 백업 파일 (아이콘/로고 교체 시 남기는 .bak 등)
*.bak

# 로컬 설명용 HTML 문서 — 저장소에 안 올림 (프로젝트 문서는 docs/*.md)
docs/*.html

# onnxruntime-web 런타임 WASM — npm run setup 이 node_modules 에서 복사 (산출물, ~40MB)
frontend/public/ort-wasm-simd-threaded.jsep.*
frontend/public/ort-wasm-simd-threaded.jspi.*
